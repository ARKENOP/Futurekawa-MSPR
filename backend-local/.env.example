# ==============================================================================
# FutureKawa MSPR — Backend Local Environment Configuration Template
# ==============================================================================
# Copy this file to `.env` (or `.env.bresil`, `.env.equateur`, `.env.colombie`) 
# and adjust the values according to the target country deployment.
# ==============================================================================

# ── Country Identity ──────────────────────────────────────────────────────────
# Two-letter ISO country code (e.g., BR, EC, CO)
COUNTRY_CODE=BR
# Full name of the country (used in alerts, reports, and UI)
COUNTRY_NAME=Brésil

# ── Ideal Storage Conditions (Strictly for this country's coffee beans) ───────
# Ideal temperature target in degrees Celsius
TEMPERATURE_IDEALE_C=29
# Ideal humidity target in percentage (0-100)
HUMIDITE_IDEALE_POURCENT=55

# ── Tolerances (Triggers alert if exceeded) ──────────────────────────────────
# Temperature variation tolerated around the ideal target (in Celsius)
TOLERANCE_TEMPERATURE_C=3
# Humidity variation tolerated around the ideal target (in percentage)
TOLERANCE_HUMIDITE_POURCENT=2

# ── Lot Expiry ────────────────────────────────────────────────────────────────
# Maximum number of days a lot is allowed to remain in storage before expiration
DUREE_MAX_STOCKAGE_JOURS=365

# ── MQTT Broker & Consumer Configuration ──────────────────────────────────────
# MQTT connection URL (use `tcp://mosquitto:1883` inside docker network)
MQTT_BROKER_URL=tcp://mosquitto:1883
# MQTT topic subscription pattern (interpolates COUNTRY_CODE)
MQTT_TOPIC=futurekawa/${COUNTRY_CODE}/entrepot/+/mesures
# Unique client ID for the backend MQTT connection
MQTT_CLIENT_ID=backend-local-${COUNTRY_CODE}
# Quality of Service level (0, 1, or 2)
MQTT_QOS=1

# ── PostgreSQL Database ───────────────────────────────────────────────────────
# Database host name (use `postgres` inside docker-compose)
POSTGRES_HOST=postgres
# Database connection port (default PostgreSQL port is 5432)
POSTGRES_PORT=5432
# Database name specific to this country deployment
POSTGRES_DB=futurekawa_${COUNTRY_CODE}
# Database username
POSTGRES_USER=futurekawa
# Database password (change in production!)
POSTGRES_PASSWORD=changeme

# ── Odoo Integration (ERP, Authentication, and Email Alerts) ──────────────────
# Base URL where Odoo 18 is running
ODOO_URL=http://odoo:8069
# Target Odoo database name
ODOO_DB=futurekawa
# Odoo API Username / email configured for backend operations
ODOO_API_USER=api-backend@futurekawa.local
# Odoo API Key / user password for programmatic calls (XML-RPC / JSON-RPC)
ODOO_API_KEY=changeme-odoo-api-key
# Destination email address where all alert notifications will be sent
ALERTE_DESTINATAIRE_EMAIL=responsable.br@futurekawa.local

# ── OpenID Connect (Odoo acts as Identity Provider) ───────────────────────────
# Issuer URI for validating OAuth2 / OIDC JSON Web Tokens (JWT)
SPRING_SECURITY_OAUTH2_RESOURCESERVER_JWT_ISSUER_URI=http://odoo:8069/auth/oidc
# JSON Web Key Set (JWKS) URL to download the OIDC public signature keys
OIDC_JWKS_URI=http://odoo:8069/auth/oidc/.well-known/jwks.json

# ── Local Server Port ─────────────────────────────────────────────────────────
# HTTP port on which the Spring Boot application will listen
SERVER_PORT=8081
