<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ── Form View ─────────────────────────────────────────────────────── -->
    <record id="view_quality_alert_form" model="ir.ui.view">
        <field name="name">futurekawa.quality.alert.form</field>
        <field name="model">futurekawa.quality.alert</field>
        <field name="arch" type="xml">
            <form string="Alerte Qualite">
                <header>
                    <button name="action_investigate" type="object" string="Demarrer l'analyse"
                            class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" type="object" string="Valider / Resoudre"
                            class="oe_highlight" invisible="state in ('resolved', 'rejected')"/>
                    <button name="action_reject" type="object" string="Declasser le Lot"
                            class="btn-danger" invisible="state in ('resolved', 'rejected')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,investigation,resolved,rejected"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Origine">
                            <field name="entrepot_nom"/>
                            <field name="pays_code"/>
                            <field name="lot_reference"/>
                            <field name="date_creation"/>
                            <field name="backend_alerte_id"/>
                        </group>
                        <group string="Classification">
                            <field name="type_anomaly"/>
                            <field name="niveau"/>
                            <field name="valeur_enregistree"/>
                            <field name="valeur_cible"/>
                            <field name="responsable_id"/>
                            <field name="date_resolution"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="message_description"/>
                        </page>
                        <page string="Notes d'Audit">
                            <field name="notes_audit"
                                   placeholder="Origine de l'anomalie et actions correctives prises..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── List View ─────────────────────────────────────────────────────── -->
    <record id="view_quality_alert_list" model="ir.ui.view">
        <field name="name">futurekawa.quality.alert.list</field>
        <field name="model">futurekawa.quality.alert</field>
        <field name="arch" type="xml">
            <list string="Alertes Qualite"
                  decoration-danger="niveau == 'critique'"
                  decoration-warning="niveau == 'warning'"
                  decoration-muted="state in ('resolved', 'rejected')">
                <field name="name"/>
                <field name="date_creation"/>
                <field name="entrepot_nom"/>
                <field name="pays_code"/>
                <field name="type_anomaly"/>
                <field name="niveau" widget="badge"
                       decoration-danger="niveau == 'critique'"
                       decoration-warning="niveau == 'warning'"
                       decoration-info="niveau == 'info'"/>
                <field name="lot_reference"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'resolved'"
                       decoration-danger="state == 'draft'"/>
            </list>
        </field>
    </record>

    <!-- ── Search View ───────────────────────────────────────────────────── -->
    <record id="view_quality_alert_search" model="ir.ui.view">
        <field name="name">futurekawa.quality.alert.search</field>
        <field name="model">futurekawa.quality.alert</field>
        <field name="arch" type="xml">
            <search string="Rechercher une alerte">
                <field name="name"/>
                <field name="entrepot_nom"/>
                <field name="lot_reference"/>
                <filter name="open" string="Ouvertes" domain="[('state', 'not in', ('resolved', 'rejected'))]"/>
                <filter name="critique" string="Critiques" domain="[('niveau', '=', 'critique')]"/>
                <group expand="0" string="Regrouper par">
                    <filter name="group_entrepot" string="Entrepot" context="{'group_by': 'entrepot_nom'}"/>
                    <filter name="group_niveau" string="Niveau" context="{'group_by': 'niveau'}"/>
                    <filter name="group_state" string="Statut" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Window Action ─────────────────────────────────────────────────── -->
    <record id="action_quality_alerts" model="ir.actions.act_window">
        <field name="name">Fiches de Non-Conformite</field>
        <field name="res_model">futurekawa.quality.alert</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_open': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiley_face">Aucune alerte qualite</p>
            <p>Les alertes remontees par les capteurs IoT des entrepots apparaitront ici.</p>
        </field>
    </record>

    <!-- ── Menus ─────────────────────────────────────────────────────────── -->
    <menuitem id="menu_futurekawa_root" name="FutureKawa Quality" sequence="10"/>
    <menuitem id="menu_quality_alerts" name="Alertes"
              parent="menu_futurekawa_root" action="action_quality_alerts" sequence="10"/>
</odoo>
