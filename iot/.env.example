# ==============================================================================
# FutureKawa MSPR — IoT & Simulator Environment Configuration Template
# ==============================================================================
# Copy this file to `.env` in the `iot` directory.
# Used by the Python MQTT simulator and as a reference for ESP32 firmware config.
# ==============================================================================

# ── Wi-Fi Configuration (Reference for ESP32 config.h) ────────────────────────
# Wi-Fi SSID / Network name
WIFI_SSID=FutureKawa-Local
# Wi-Fi Network Password
WIFI_PASSWORD=changeme

# ── MQTT Configuration ────────────────────────────────────────────────────────
# IP or hostname of the Eclipse Mosquitto MQTT broker
# Use `localhost` for local simulator testing, or the container host IP for ESP32
MQTT_BROKER=localhost
# MQTT connection port (default is 1883)
MQTT_PORT=1883
# Unique client identifier for the MQTT connection
MQTT_CLIENT_ID=esp32-br-01
# Topic where readings will be published
# Format: futurekawa/{codePays}/entrepot/{idEntrepot}/mesures
MQTT_TOPIC=futurekawa/BR/entrepot/1/mesures
# Quality of Service level (0 or 1 - QoS 1 is recommended for reliability)
MQTT_QOS=1

# ── ESP32 Sensor & Hardware Settings ──────────────────────────────────────────
# ESP32 GPIO pin connected to the DHT22 data pin
DHT_PIN=4
# Sensor type (DHT11 or DHT22)
DHT_TYPE=DHT22
# Measurement interval in milliseconds (e.g., 30000 ms = 30 seconds)
READ_INTERVAL_MS=30000

# ── Python Simulator Settings (iot/simulator/mqtt_simulator.py) TESTING ONLY────────────────
# Country identity code for simulator auto-topic generation (BR, EC, CO)
SIMULATOR_COUNTRY_CODE=BR
# Warehouse ID for simulator auto-topic generation
SIMULATOR_ENTREPOT_ID=1
# Read interval in seconds for the simulator
SIMULATOR_INTERVAL_SECONDS=30
# Whether the simulator should periodically inject temperature/humidity anomalies
# Set to 'true' to test the backend alerting engine and Odoo email notifications
SIMULATOR_INJECT_ANOMALIES=true
